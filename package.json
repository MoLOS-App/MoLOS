{
	"name": "molos",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "bun@1.2.10",
	"workspaces": [
		"packages/*",
		"modules/*"
	],
	"scripts": {
		"dev": "bun run module:sync-deps && bun install && bun run db:init && bun run module:sync && vite dev",
		"build": "turbo run build",
		"build:prod": "bun run fetch:modules && bun run build:prepare && bun run build",
		"preview": "vite preview --host --port 4173",
		"serve": "bun build/index.js",
		"fetch:modules": "tsx scripts/fetch-modules.ts",
		"fetch:module": "tsx scripts/fetch-modules.ts --single",
		"build:prepare": "tsx scripts/build-modules.ts",
		"module:sync": "tsx scripts/sync-modules.ts",
		"module:link": "tsx scripts/link-modules.ts",
		"module:sync-deps": "tsx scripts/sync-workspace-modules.ts",
		"module:create": "tsx scripts/module-dev-cli.ts create",
		"module:validate": "tsx scripts/module-dev-cli.ts validate",
		"module:test": "tsx scripts/module-dev-cli.ts test",
		"module:cleanup": "tsx scripts/cleanup-module-symlinks.ts",
		"module:tui": "tsx scripts/module-tui.ts",
		"db:init": "tsx scripts/init-database.ts",
		"db:audit-modules": "tsx scripts/audit-module-migrations.ts",
		"db:generate": "turbo run db:generate",
		"db:migrate": "turbo run db:migrate",
		"db:migrate:unified": "tsx packages/database/src/migrate-unified.ts",
		"db:validate": "tsx packages/database/src/schema-validator.ts",
		"db:push": "drizzle-kit push",
		"db:reset": "drizzle-kit reset",
		"db:studio": "drizzle-kit studio",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "turbo run lint",
		"lint:root": "eslint .",
		"test": "turbo run test",
		"test:unit": "vitest",
		"typecheck": "turbo run typecheck",
		"clean": "turbo run clean",
		"docker:build": "docker build -t ghcr.io/molos-app/molos:latest .",
		"docker:push": "docker push ghcr.io/molos-app/molos:latest",
		"docker:dev": "bun run docker:build && bun run docker:push",
		"podman:build": "podman build -t ghcr.io/molos-app/molos:latest .",
		"podman:push": "podman push ghcr.io/molos-app/molos:latest",
		"podman:dev": "bun run podman:build && bun run podman:push"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@rollup/rollup-linux-x64-gnu": "^4.9.6",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/line-clamp": "^0.4.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@tanstack/table-core": "^8.21.3",
		"@types/better-sqlite3": "^7.6.13",
		"@types/blessed": "^0.1.21",
		"@types/inquirer": "^9.0.9",
		"@types/node": "^20",
		"@vitest/browser-playwright": "^4.0.15",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.8",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"formsnap": "^2.0.1",
		"globals": "^16.5.0",
		"inquirer": "^13.1.0",
		"layerchart": "2.0.0-next.43",
		"mdsvex": "^0.12.6",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.28.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"tsx": "^4.21.0",
		"turbo": "^2.5.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.2.6",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.0.1"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.43",
		"@ai-sdk/openai": "^3.0.28",
		"@ai-sdk/svelte": "^4.0.85",
		"@better-auth/core": "^1.4.18",
		"@better-auth/utils": "^0.3.0",
		"@better-fetch/fetch": "^1.1.21",
		"@dagrejs/dagre": "^2.0.4",
		"@floating-ui/core": "^1.7.4",
		"@floating-ui/dom": "^1.7.5",
		"@floating-ui/utils": "^0.2.10",
		"@layerstack/svelte-actions": "1.0.1-next.14",
		"@layerstack/svelte-state": "0.1.0-next.19",
		"@layerstack/tailwind": "2.0.0-next.17",
		"@layerstack/utils": "2.0.0-next.14",
		"@modelcontextprotocol/sdk": "^1.25.3",
		"@molos/module-ai": "workspace:*",
		"@molos/module-ai-knowledge": "workspace:*",
		"@molos/module-finance": "workspace:*",
		"@molos/module-goals": "workspace:*",
		"@molos/module-google": "workspace:*",
		"@molos/module-health": "workspace:*",
		"@molos/module-llm-council": "workspace:*",
		"@molos/module-markdown": "workspace:*",
		"@molos/module-meals": "workspace:*",
		"@molos/module-sample": "workspace:*",
		"@molos/module-tasks": "workspace:*",
		"@noble/hashes": "^2.0.1",
		"@sinclair/typebox": "^0.34.48",
		"ai": "^6.0.84",
		"animejs": "^4.2.2",
		"better-auth": "1.4.7",
		"better-sqlite3": "^12.5.0",
		"blessed": "^0.1.81",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.41.0",
		"jose": "^6.1.0",
		"marked": "^17.0.1",
		"molos-tasks": "workspace:*",
		"nanostores": "^1.1.0",
		"runed": "^0.37.1",
		"svelte-marked": "^0.8.0",
		"technicalindicators": "^3.1.0",
		"yaml": "^2.8.2",
		"zod": "^4.3.6"
	}
}
