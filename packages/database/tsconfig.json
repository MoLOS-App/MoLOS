{
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"module": "ESNext",
		"target": "ES2022",
		"types": ["node"],
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"customConditions": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "drizzle"]
}
