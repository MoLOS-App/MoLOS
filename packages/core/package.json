{
	"name": "@molos/core",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Core utilities and types for MoLOS",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./utils": {
			"types": "./dist/utils/index.d.ts",
			"import": "./dist/utils/index.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/types/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"typescript": "^5.9.3"
	}
}
